{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "node build.js",
      "problemMatcher": {
        "owner": "yaml",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^YAMLException:(.*) at line (\\d+), column (\\d+):(.*)$",
          "message": 1,
          "line": 2,
          "column": 3
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "promptOnClose": true
    },
    {
      "label": "package",
      "type": "shell",
      "command": "npx @vscode/vsce package --out packages/",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}